# Database Configuration
DATABASE_URL=postgresql://smartfu_user:smartfu_dev_password@localhost:5432/smartfu
DB_PASSWORD=smartfu_dev_password

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# API Keys
# IMPORTANT: Replace with your actual Anthropic API key
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional: Other LLM providers (future use)
# OPENAI_API_KEY=sk-...

# Security Configuration
# IMPORTANT: Change SECRET_KEY in production!
SECRET_KEY=your-secret-key-min-32-characters-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Application Configuration
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ML Models Configuration
MODELS_PATH=./models
ENABLE_MODEL_TRAINING=True

# Email Configuration (Optional - for follow-up notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@smartfu.com

# SMS Configuration (Optional - Twilio)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_FROM_NUMBER=+1234567890

# File Upload Configuration
MAX_UPLOAD_SIZE_MB=50
ALLOWED_UPLOAD_EXTENSIONS=csv,xlsx

# Feature Flags
ENABLE_AI_AGENTS=True
ENABLE_EMAIL_FOLLOWUPS=False
ENABLE_SMS_FOLLOWUPS=False
ENABLE_SIGNAL_DETECTION=True

# Monitoring (Optional)
SENTRY_DSN=
ENABLE_ANALYTICS=True
